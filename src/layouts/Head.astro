---
import { Font } from 'astro:assets';

export interface Props {
  title?: string;
  description?: string;
  themeColor?: string;
  image?: string;
}

const { title, description, themeColor, image } = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, Astro.site).href;
const ogImage = image ? new URL(image, Astro.site).href : undefined;

const structuredData = [
  {
    "@context": "https://schema.org",
    "@type": "Person",
    "name": "Klas Näsman",
    "url": "https://klasnasman.com",
    "jobTitle": "Designer & Webbutvecklare",
    "description": "Klas Näsman är en designer och webbutvecklare baserad i Stockholm, Sverige",
    "address": {
      "@type": "PostalAddress",
      "addressLocality": "Stockholm",
      "addressCountry": "SE"
    },
    "sameAs": [
      "https://github.com/klasnasman",
      "https://www.linkedin.com/in/klasnasman/"
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    "name": "Klas Näsman",
    "url": "https://klasnasman.com",
    "description": "Klas Näsman är en designer och webbutvecklare baserad i Stockholm, Sverige",
    "author": {
      "@type": "Person",
      "name": "Klas Näsman"
    }
  }
];
---

<head>
  <meta charset="UTF-8" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="generator" content={Astro.generator} />
  <meta name="robots" content="index, follow" />
  <link rel="canonical" href={canonicalURL} />

  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content="website" />
  <meta property="og:url" content={canonicalURL} />
  <meta property="og:site_name" content="Klas Näsman" />
  <meta property="og:locale" content="sv_SE" />
  {ogImage && <meta property="og:image" content={ogImage} />}

  <meta name="twitter:card" content="summary" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  {ogImage && <meta name="twitter:image" content={ogImage} />}

  <meta name="theme-color" content={themeColor} />
  <link rel="icon" type="image/png+xml" href="/favicon.png" />
  <link rel="manifest" href="/manifest.json" />
  <script is:inline data-goatcounter="https://klasnasman.goatcounter.com/count" async src="//gc.zgo.at/count.js"></script>
  <Font cssVariable='--font-iserif' preload />
  <script is:inline type="application/ld+json" set:html={JSON.stringify(structuredData)} />
  <script is:inline>
    const stored = localStorage.getItem("darkMode");
    const prefersDark = window.matchMedia("(prefers-color-scheme: dark)").matches;
    if (stored === "enabled" || (stored === null && prefersDark)) {
      document.documentElement.classList.add("darkmode");
    }
  </script>
  <!-- site by Out Surfing Studio -->
</head>