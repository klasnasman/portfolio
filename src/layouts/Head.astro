---
import { AstroFont } from "astro-font";

export interface Props {
  title?: string;
  description?: string;
  themeColor?: string;
}

const { title, description, themeColor } = Astro.props;
const canonicalURL = (Astro.url.pathname, Astro.site);
---

<head>
  <meta charset="UTF-8" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="generator" content={Astro.generator} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content="website" />
  <meta property="og:url" content={canonicalURL} />
  <meta name="theme-color" content={themeColor} />
  <link rel="canonical" href={canonicalURL} />
  <link rel="icon" type="image/png+xml" href="/favicon.png" />
  <link rel="manifest" href="/manifest.json" />
  <script data-goatcounter="https://klasnasman.goatcounter.com/count" async src="//gc.zgo.at/count.js"></script>
  <AstroFont
      config={[
        {
          name: "Necto Mono",
          src: [
            {
              style: 'normal',
              weight: '400',
              path: '/fonts/NectoMono-Regular.woff2'
            },
          ],
          preload: true,
          display: "block",
          fallback: "serif",
        },
      ]}
    />
  <script is:inline type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Person",
    "name": "Klas Näsman",
    "url": "https://klasnasman.com",
    "jobTitle": "Designer & Web Developer",
    "description": "Klas Näsman is a designer and web developer based in Stockholm, Sweden",
    "address": {
      "@type": "PostalAddress",
      "addressLocality": "Stockholm",
      "addressCountry": "SE"
    },
    "sameAs": [
      "https://github.com/klasnasman",
      "https://www.linkedin.com/in/klasnasman/",
      "https://read.cv/klas"
    ]
  })} />
  <!-- site by Out Surfing Studio -->
</head>