<header class="header">
  <a class="header__logo" href="/"><h1>Klas Näsman</h1></a>
  <nav>
    <div>
      <a href="#about">Om</a>
    </div>
    <div>
      <p class="nav__projects">Projekt:</p>
      <a href="#selected">Urval</a>
      <a href="#all">Alla</a>
    </div>
  </nav>
</header>

<script>
  document.querySelectorAll('header nav a[href^="#"]').forEach((link) => {
    link.addEventListener("click", (e) => {
      e.preventDefault();
      const target = document.querySelector(link.getAttribute("href"));
      if (target) target.scrollIntoView({ behavior: "smooth" });
    });
  });
</script>
